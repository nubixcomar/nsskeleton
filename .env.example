# ============================================================================
# nsSkeleton — Plantilla de variables de entorno
# Copiá este archivo a `.env` y completá los valores. NUNCA commitees `.env`.
# ============================================================================

# --- Aplicación ---------------------------------------------------------------
APP_NAME="Mi Proyecto"
APP_ENV=local                 # local | staging | production
APP_DEBUG=true                # false en producción
APP_URL=http://localhost/skeleton
APP_TIMEZONE=America/Argentina/Buenos_Aires
# Assets frontend: local (sin CDN, requiere compilar con tools/build-css.sh) | cdn
ASSETS_MODE=local
# Clave para cifrar secretos en reposo (SMTP, API de IA). Generar con:
#   php system/console/key.php
APP_KEY=

# --- Base de datos (MySQL) ----------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306                   # MySQL estándar es 3306; algunos XAMPP usan 3307
DB_NAME=ns_skeleton
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- FTP / Deploy -------------------------------------------------------------
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASS=
FTP_REMOTE_PATH=/public_html
DEPLOY_BRANCH=main

# --- Repositorio --------------------------------------------------------------
GIT_REMOTE_URL=
GIT_USER=
GIT_TOKEN=                    # token de acceso (no la contraseña)

# --- Email (SMTP) -------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls           # tls | ssl | none
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# --- Backups ------------------------------------------------------------------
BACKUP_PATH=storage/backups
BACKUP_RETENTION_DAYS=30

# --- Conector de IA (configurable por proyecto) -------------------------------
# Soporte previsto: OpenAI / ChatGPT, Deepseek. Las credenciales se guardan
# cifradas; estas son solo defaults de arranque.
AI_PROVIDER=                  # openai | deepseek
AI_API_KEY=
AI_MODEL=

# --- Capa agéntica (instalador) ----------------------------------------------
# IA con la que se materializa la capa agéntica de este proyecto.
AGENTIC_TARGET=               # claude-code | openai | none

# Versión de la app derivada (el core nsSkeleton se versiona en el archivo VERSION)
APP_VERSION=1.0.0
